# =============================================
# AI Sales Agent - Environment Variables
# =============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ---------------------------------------------
# Core
# ---------------------------------------------

# Application environment: development | test | production
NODE_ENV=development

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_sales_agent

# Redis connection string (used for BullMQ job queues and caching)
REDIS_URL=redis://localhost:6379

# Port the API server listens on
API_PORT=3001

# Host the API server binds to
API_HOST=0.0.0.0

# Public-facing URL of the API (used in OAuth callbacks and webhooks)
API_PUBLIC_URL=http://localhost:3001

# Frontend origin allowed by CORS (must match the web app URL)
CORS_ORIGIN=http://localhost:3000

# ---------------------------------------------
# Auth
# ---------------------------------------------

# Secret for signing JWT access tokens (min 16 chars, 32+ recommended)
JWT_SECRET=your-secret-here-min-16-chars

# Secret for signing JWT refresh tokens (min 16 chars, 32+ recommended)
JWT_REFRESH_SECRET=your-refresh-secret-min-16-chars

# Access token expiry duration
JWT_EXPIRES_IN=15m

# Refresh token expiry duration
JWT_REFRESH_EXPIRES_IN=7d

# ---------------------------------------------
# AI
# ---------------------------------------------

# Anthropic API key for Claude (leave empty to use mock/rule-based mode)
ANTHROPIC_API_KEY=

# Claude model to use for email generation and reply classification
AI_MODEL=claude-sonnet-4-6

# ---------------------------------------------
# Email
# ---------------------------------------------

# Enable real email sending via Resend (set to "true" in production)
EMAIL_ENABLED=false

# Resend API key (https://resend.com) - required when EMAIL_ENABLED=true
RESEND_API_KEY=

# Default sender email address
EMAIL_FROM=outreach@yourdomain.com

# Resend webhook HMAC secret for verifying inbound webhook signatures
RESEND_WEBHOOK_SECRET=

# ---------------------------------------------
# Google OAuth (Gmail sending)
# ---------------------------------------------

# Google OAuth 2.0 client ID (from Google Cloud Console)
GOOGLE_CLIENT_ID=

# Google OAuth 2.0 client secret
GOOGLE_CLIENT_SECRET=

# Google OAuth callback URL (must match your Google Cloud Console config)
GOOGLE_REDIRECT_URI=http://localhost:3001/api/v1/email-accounts/google/callback

# ---------------------------------------------
# HubSpot CRM
# ---------------------------------------------

# HubSpot OAuth app client ID (from HubSpot developer portal)
HUBSPOT_CLIENT_ID=

# HubSpot OAuth app client secret
HUBSPOT_CLIENT_SECRET=

# HubSpot OAuth callback URL
HUBSPOT_REDIRECT_URI=http://localhost:3001/api/v1/crm/hubspot/callback

# ---------------------------------------------
# App URLs
# ---------------------------------------------

# API base URL used by the Next.js frontend (include /api/v1 prefix)
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Public URL of the Next.js web app (used for links in emails, redirects, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000
